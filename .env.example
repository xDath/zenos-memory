# Zenos Memory Environment Template
# Copy this file to .env.local for local development.
# Never put real secrets in files that will be committed.

# Runtime mode
USE_LOCAL_STORE=false

# Etla/Hermes API protection
ETLA_MASTER_SECRET=change_me
ZENOS_MEMORY_API_KEY=change_me

# Google Drive OAuth storage
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=your_google_oauth_refresh_token
ZENOS_MEMORY_DRIVE_FOLDER_ID=root_or_folder_id
ZENOS_MEMORY_DRIVE_STRUCTURED=true

# Optional legacy service account fallback (not recommended for My Drive)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
# GOOGLE_SERVICE_ACCOUNT_FILE=/secure/path/service-account.json

# LLM enhancer (OpenAI-compatible router)
MEMORY_LLM_BASE_URL=https://router.example.com/v1
MEMORY_LLM_API_KEY=your_router_api_key
MEMORY_LLM_MODEL=provider/model-name
MEMORY_LLM_FALLBACK_MODEL=provider/fallback-model

# Optional embeddings
MEMORY_EMBEDDING_MODEL=text-embedding-3-small

# Vercel cron protection
CRON_SECRET=change_me

# Optional defaults
DEFAULT_NAMESPACE=zenos
DEBUG=false
