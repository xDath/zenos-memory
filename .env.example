# Zenos Memory 2.5.0 environment template
# Copy only the values needed by the target environment. Never commit real secrets.

NODE_ENV=production
ZENOS_MEMORY_STORAGE_MODE=drive-events
ZENOS_MEMORY_DEFAULT_NAMESPACE=zenos
ZENOS_MEMORY_IMPORT_LEGACY_ON_START=true
ZENOS_MEMORY_CLOUD_REFRESH_MS=1000
ZENOS_MEMORY_WRITE_LEASE_MS=90000
ZENOS_MEMORY_WRITE_WAIT_MS=15000
ZENOS_MEMORY_EVENT_UPLOAD_CONCURRENCY=4
ZENOS_MEMORY_SNAPSHOT_RETENTION=14
ZENOS_MEMORY_BACKUP_DAY_RETENTION=14
ZENOS_MEMORY_PRUNE_TEST_NAMESPACES=true
ZENOS_MEMORY_TEST_NAMESPACE_RETENTION_HOURS=24
# Verified checkpoints must pass claim-to-evidence faithfulness before replacing prior state.
ZENOS_MEMORY_EVIDENCE_FAITHFULNESS_ENABLED=true
# ContinuityPacket v2 is deterministic-first to fit the serverless write deadline.
# Enable only for a measured shadow experiment with sufficient function duration.
ZENOS_MEMORY_CONTINUITY_LLM_ENABLED=false

# Authentication: production must configure a signing secret.
ETLA_MASTER_SECRET=replace_with_a_long_random_secret
# ZENOS_MEMORY_SECRET=replace_with_a_long_random_secret
ZENOS_MEMORY_ALLOW_INSECURE_DEV=false
ZENOS_MEMORY_ALLOW_STATIC_API_KEY=false
ZENOS_MEMORY_ALLOW_LEGACY_HMAC=false
ZENOS_MEMORY_ALLOW_ADMIN_TOKEN_EXCHANGE=true

# Canonical Google Drive event store.
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=your_google_oauth_refresh_token
GOOGLE_DRIVE_FOLDER_NAME=Zenos Memory
# ZENOS_MEMORY_DRIVE_FOLDER_ID=optional_existing_folder_id

# Vercel Cron authentication.
CRON_SECRET=replace_with_a_long_random_secret

# Optional OpenAI-compatible LLM and embedding providers.
MEMORY_LLM_BASE_URL=https://router.example.com/v1
MEMORY_LLM_API_KEY=your_router_api_key
MEMORY_LLM_MODEL=ag/gemini-pro-agent
MEMORY_LLM_FALLBACK_MODEL=ag/gemini-3.5-flash-low
MEMORY_LLM_TIMEOUT_MS=22000
MEMORY_LLM_TOTAL_BUDGET_MS=48000
# Optional overrides when embeddings use a different OpenAI-compatible provider.
# MEMORY_EMBEDDING_BASE_URL=https://embedding-provider.example.com/v1
# MEMORY_EMBEDDING_API_KEY=your_embedding_api_key
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EMBEDDING_TIMEOUT_MS=30000
# When a dense provider is unavailable, use the configured LLM to create
# language-neutral semantic retrieval representations before hashing.
MEMORY_SEMANTIC_EXPANSION_ENABLED=true
MEMORY_SEMANTIC_EXPANSION_MODEL=ag/gemini-3.5-flash-low
MEMORY_SEMANTIC_EXPANSION_FALLBACK_MODEL=ag/gemini-3-flash
MEMORY_SEMANTIC_EXPANSION_TIMEOUT_MS=16000
MEMORY_SEMANTIC_EXPANSION_TOTAL_BUDGET_MS=30000

# Local development or emergency fallback only.
# Omit ZENOS_MEMORY_STORAGE_MODE or set it to local-sqlite.
# ZENOS_MEMORY_DB_PATH=.data/zenos-memory.sqlite
# ZENOS_MEMORY_BACKUP_DIR=.data/backups
# PORT=3091
# HOSTNAME=127.0.0.1
