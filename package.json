{
  "name": "zenos-memory",
  "version": "2.3.1",
  "private": true,
  "description": "A serverless, user-owned context continuity service powered by Vercel compute and Google Drive events.",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev -p 3091",
    "build": "next build --webpack --experimental-build-mode compile && next build --webpack --experimental-build-mode generate && node scripts/prepare-standalone.mjs",
    "start": "node scripts/load-env-and-start.mjs",
    "lint": "eslint --max-warnings=0",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "tsx --test tests/*.test.ts",
    "test:coverage": "tsx --test --experimental-test-coverage --test-coverage-lines=75 --test-coverage-branches=70 --test-coverage-functions=75 tests/*.test.ts",
    "test:smoke": "tsx test-memory.ts",
    "check": "npm run typecheck && npm run lint && npm test && npm run test:smoke && npm run build",
    "cli": "node scripts/zenos-memory-cli.mjs",
    "smoke:prod": "node scripts/smoke-production.mjs",
    "smoke:semantic": "node scripts/smoke-semantic-production.mjs",
    "smoke:cloud": "tsx scripts/smoke-cloud-drive.mts",
    "smoke:concurrency": "tsx scripts/smoke-cloud-concurrency.mts",
    "maintenance": "node scripts/run-maintenance.mjs",
    "diagnose:auth": "node scripts/check-auth-scopes.mjs",
    "diagnose:drive": "tsx scripts/inspect-drive-layout.mjs",
    "migrate:drive-events": "tsx scripts/migrate-drive-events.mts",
    "migrate:legacy-vercel": "tsx scripts/migrate-legacy-vercel.mts",
    "deploy:local": "bash deploy/install-local-service.sh"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "dependencies": {
    "googleapis": "^173.0.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "uuid": "^14.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.22.5",
    "typescript": "^5"
  }
}
