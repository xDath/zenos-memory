# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.py[cod]

# Local Zenos Runtime working copies do not belong to the Memory product.
/app/api/memory/runtime/
/app/lib/zenos-runtime.ts
/app/lib/zenos-runtime-executor.ts
/docs/zenos-runtime-*.md
/scripts/zenos-runtime-cli.mjs
/scripts/smoke-runtime.mjs
/zenos-runtime-roadmap.md
